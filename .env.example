# Copy this file to .env and fill in real values. Never commit .env.

# Flask session signing key. App fails fast (sys.exit) if this is missing.
SECRET_KEY=change-me-to-a-random-secret

# Neon PostgreSQL full-access connection string (read/write).
DATABASE_URL=postgresql://user:password@host/dbname

# Neon read-only role — used only by the Phase 5 NL->SQL layer.
AI_DB_URL=postgresql://readonly_user:password@host/dbname

# Gemini 2.5 Flash API key (Phase 5 only).
GEMINI_API_KEY=your-gemini-api-key
